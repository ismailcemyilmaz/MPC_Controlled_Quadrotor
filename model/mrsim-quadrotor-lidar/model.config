<?xml version="1.0"?>
<model>
  <name>mrsim-quadrotor-lidar</name>
  <version>1.0</version>
  <sdf version="1.5">model.sdf</sdf>
  <author>
    <name>LAAS/CNRS (lidar eklendi)</name>
    <email>openrobots@laas.fr</email>
  </author>
  <description>
    A quadrotor with 2D lidar sensor (360 deg, 10 Hz, topic: /lidar/scan).
    Lidar mounted 6cm above base center, min_range=0.10m, max_range=8.0m.
  </description>
</model>
